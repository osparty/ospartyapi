# MAIN server (.env next to docker-compose.main.yml). Copy to `.env` on MAIN and fill in real values.
# The real .env is gitignored. Private IPs: MAIN 10.0.0.2 · node-1 10.0.0.3 · node-2 10.0.0.4.

# This box's private IP. Redis + the bot publish on it; the API reaches the bot at http://10.0.0.2:8090.
MAIN_PRIVATE_IP=10.0.0.2

# Shared Redis password (also set on both nodes' .env, identical). Generate: openssl rand -hex 32
REDIS_PASSWORD=change-me-to-a-long-random-string

# Shared secret the API sends to the discord-bot. Must equal DISCORD_INTERNAL_TOKEN in the bot's .env
# and in both nodes' .env. Generate: openssl rand -hex 32
DISCORD_INTERNAL_TOKEN=change-me-to-a-long-random-string

# OAuth2 account linking (blank = linking disabled). Same values on MAIN and both nodes.
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=your-client-secret-here
DISCORD_REDIRECT_URI=https://api.osparty.net/api/v1/discord/link/callback

# Grafana (monitoring stack on MAIN). Login user is `admin`.
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ROOT_URL=https://monitoring.osparty.net
GRAFANA_HTTP_PORT=3001

# Pin a specific image on the server (optional; the deploy workflow exports the exact tag). For manual
# rollback: IMAGE_TAG=1.2.2 docker compose -f docker-compose.main.yml up -d
# IMAGE_TAG=latest
