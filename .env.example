# Copy to `.env` next to docker-compose.yml on the server and fill in the real values.
# docker compose reads this automatically and injects it into the `api` container.
# The real `.env` is gitignored — never commit secrets.

# Voice-channel provisioning is delegated to the separate osparty-discord service. Point this at the bot;
# leave blank to run without voice. The bot's token/guild/category live in ITS .env, not here.
#   local:      http://host.docker.internal:8090
#   private net: http://<main-private-ip>:8090
DISCORD_SERVICE_URL=http://host.docker.internal:8090

# Shared secret sent to the bot as X-Internal-Token. Must match DISCORD_INTERNAL_TOKEN in the bot's .env.
DISCORD_INTERNAL_TOKEN=change-me-to-a-long-random-string

# OAuth2 account linking (accountHash <-> Discord user) stays in the API. Leave blank to disable linking.
# client-id = the Discord application id. client-secret from OAuth2 -> Client Secret.
# redirect-uri must be registered under OAuth2 -> Redirects and match exactly.
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=your-client-secret-here
DISCORD_REDIRECT_URI=https://api.osparty.net/api/v1/discord/link/callback

# Grafana admin password + public URL for the monitoring stack (Prometheus + Grafana).
# Grafana is served at GRAFANA_ROOT_URL via the Nginx Proxy Manager stack (Proxy Host ->
# host.docker.internal:${GRAFANA_HTTP_PORT}). Login user is `admin`.
# GRAFANA_HTTP_PORT is the host port Grafana publishes on; 3000 is often taken on a shared box,
# so this defaults to 3001. Set the NPM Proxy Host's Forward Port to match.
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ROOT_URL=https://monitoring.osparty.net
GRAFANA_HTTP_PORT=3001
