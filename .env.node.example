# Worker NODE (.env next to docker-compose.node.yml). Copy to `.env` on EACH node and fill in real values.
# The real .env is gitignored. Private IPs: MAIN 10.0.0.2 · node-1 10.0.0.3 · node-2 10.0.0.4.

# MAIN's private IP — where this node reaches the shared Redis (:6379) and the discord-bot (:8090).
MAIN_PRIVATE_IP=10.0.0.2

# THIS node's private IP — the API's 8080 (for NPM) and 9090 (for Prometheus) bind to it only.
#   node-1: 10.0.0.3   |   node-2: 10.0.0.4
NODE_PRIVATE_IP=10.0.0.3

# Must match MAIN's REDIS_PASSWORD exactly.
REDIS_PASSWORD=change-me-to-a-long-random-string

# Must match MAIN's / the bot's DISCORD_INTERNAL_TOKEN exactly.
DISCORD_INTERNAL_TOKEN=change-me-to-a-long-random-string

# OAuth2 account linking — same values as MAIN (a node may serve the callback). Blank = disabled.
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=your-client-secret-here
DISCORD_REDIRECT_URI=https://api.osparty.net/api/v1/discord/link/callback

# Optional manual pin/rollback: IMAGE_TAG=1.2.2 docker compose -f docker-compose.node.yml up -d
# IMAGE_TAG=latest
